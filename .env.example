# Local all-in-one docker compose defaults.
#
# Quick start:
#   cp .env.example .env
#   docker compose up -d
#   open http://127.0.0.1:8080

# Image tag to use for all local services. `latest` is published via GHCR.
OPENCURIA_TAG=latest

# Local ports
WEBAPP_PORT=8080
BACKEND_PORT=8000

# Local bootstrap data
LOCAL_ADMIN_EMAIL=admin@localhost.test
LOCAL_ADMIN_PASSWORD=CHANGE_ME_local_admin_password
LOCAL_ORGANIZATION_NAME=Local
LOCAL_RUNNER_NAME=local-docker
LOCAL_RUNNER_API_TOKEN=local-runner-token-change-me
LOCAL_IMAGE_DEFINITION_NAME=Local Docker Workspace

# Local backend secrets
DJANGO_SECRET_KEY=local-dev-secret-key-change-me
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=CHANGE_ME_generate_a_fernet_key_for_local_use

# Optional logging override for the local runner
RUNNER_LOG_LEVEL=INFO
RUNNER_LOG_FORMAT=console
