[Unit]
Description=opencuria runner
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/opencuria/runner
EnvironmentFile=/etc/opencuria/runner.env
ExecStart=/opt/opencuria/runner/.venv/bin/python -m src
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
