[Unit]
Description=opencuria runner
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=__RUNNER_DIR__
EnvironmentFile=__RUNNER_DIR__/.env
ExecStart=__RUNNER_DIR__/.venv/bin/python -m src
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
