#cloud-config
# Configure Ubuntu user for Packer builds with password authentication
# After build completes, password auth should be disabled for security

users:
  - name: ubuntu
    groups: [sudo]
    sudo: ALL=(ALL) NOPASSWD:ALL
    lock_passwd: false
    shell: /bin/bash

chpasswd:
  list: |
    ubuntu:packer
  expire: false

ssh_pwauth: true

# Grow root partition to fill disk
growpart:
  mode: auto
  devices: ['/']

# Configure SSH for Packer access during build
runcmd:
  - sed -i 's/^#\?PermitRootLogin.*/PermitRootLogin no/' /etc/ssh/sshd_config
  - sed -i 's/^#\?PasswordAuthentication.*/PasswordAuthentication yes/' /etc/ssh/sshd_config
  - sed -i 's/^#\?PubkeyAuthentication.*/PubkeyAuthentication yes/' /etc/ssh/sshd_config
  - systemctl restart ssh
