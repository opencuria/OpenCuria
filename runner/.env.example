# Standalone runner deployment defaults.
#
# Docker runner:
#   cp .env.example .env
#   docker compose up -d
#
# Native runner with QEMU:
#   preferred: run ./runner/scripts/setup-native-qemu-runner.sh
#   manual: copy this file to /etc/opencuria/runner.env and use runner/systemd/opencuria-runner.service

OPENCURIA_TAG=latest

# API token for authenticating with the backend.
# Create it once in the backend UI/API and copy it here.
RUNNER_API_TOKEN=

# Backend URL. Use http(s)://host:port or ws(s)://host:port.
RUNNER_BACKEND_URL=http://localhost:8000

# Docker socket path
RUNNER_DOCKER_SOCKET=unix:///var/run/docker.sock

# Docker network for workspace containers
RUNNER_DOCKER_NETWORK=bridge

# Logging
RUNNER_LOG_LEVEL=INFO
RUNNER_LOG_FORMAT=json

# Comma-separated list of enabled runtimes: "docker", "qemu", or "docker,qemu"
# Native QEMU-only hosts should usually set this to "qemu".
RUNNER_ENABLED_RUNTIMES=docker

# QEMU/KVM Settings (used only for native Linux runners)
RUNNER_QEMU_IMAGE_CACHE_DIR=/var/lib/opencuria/images
RUNNER_QEMU_DISK_DIR=/var/lib/opencuria/disks
RUNNER_QEMU_SNAPSHOT_DIR=/var/lib/opencuria/snapshots
RUNNER_QEMU_VCPUS=2
RUNNER_QEMU_MEMORY_MB=4096
RUNNER_QEMU_DISK_SIZE_GB=20
RUNNER_QEMU_NETWORK=default
RUNNER_QEMU_SSH_USER=ubuntu
