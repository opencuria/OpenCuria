# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_ENV=development
DJANGO_LOG_LEVEL=INFO

# Database (production only — dev uses SQLite)
# DB_NAME=opencuria
# DB_USER=opencuria
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432

# Redis (production only — dev uses in-memory channel layer)
# REDIS_URL=redis://localhost:6379/0

# Allowed hosts (production only, comma-separated)
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Optional external SSO (paid feature)
SSO_ENABLED=false
SSO_PROVIDER=keycloak
SSO_KEYCLOAK_BASE_URL=
SSO_KEYCLOAK_REALM=
SSO_KEYCLOAK_CLIENT_ID=
# Optional for confidential Keycloak clients:
# SSO_KEYCLOAK_CLIENT_SECRET=
SSO_KEYCLOAK_SCOPE=openid email profile
